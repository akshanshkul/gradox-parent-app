# Backend API Configuration
EXPO_PUBLIC_API_URL=https://api.gradox.in/api
# EXPO_PUBLIC_API_URL=http://192.168.1.2:8000/api

# App Mode Configuration
# Set to 'true' for multi-school platform, 'false' for dedicated school app
EXPO_PUBLIC_IS_GLOBAL_APP=true

# Single School Mode Configuration (Used if IS_GLOBAL_APP is false)
EXPO_PUBLIC_SCHOOL_ID=1
EXPO_PUBLIC_SCHOOL_SLUG=demo-school-1
EXPO_PUBLIC_SCHOOL_NAME=Demo International School
EXPO_PUBLIC_SCHOOL_LOGO=
