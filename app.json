{
  "expo": {
    "name": "Gradox Parent",
    "slug": "gradox-parent",
    "scheme": "gradox-parent",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo.png",
    "notification": {
      "icon": "./assets/logo/logo.png",
      "color": "#4f46e5"
    },
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tenextservicesllp.gradox.parent",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tenextservicesllp.gradox.parent",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "a64ce79f-4739-43b0-a0f4-0ac6a915ac6a"
      },
      "router": {},
      "isGlobalApp": true,
      "schoolName": "Demo International School",
      "schoolLogo": ""
    },
    "owner": "tenext-services-llp"
  }
}
